# PostgreSQL Database URL (Neon)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Groq AI API Key (get from https://console.groq.com)
GROQ_API_KEY=

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Node Environment
NODE_ENV=production

# Groq concurrency cap — max simultaneous AI requests (default: 25)
GROQ_MAX_CONCURRENT=25

# Upstash Redis — enables cluster-safe rate limiting across PM2 workers
# Leave blank to fall back to in-memory rate limiting (single-process only)
# Get free credentials at https://upstash.com
REDIS_URL=
REDIS_TOKEN=
